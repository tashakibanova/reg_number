# Пароль администратора для входа в приложение
VITE_ADMIN_PASSWORD=ваш_надёжный_пароль

# API-ключ UniSender (получить на unisender.com → Настройки → API)
VITE_UNISENDER_API_KEY=ваш_api_ключ

# Email отправителя (должен быть верифицирован в UniSender)
VITE_SENDER_EMAIL=noreply@example.com

# Имя отправителя (отображается в почтовом клиенте получателя)
VITE_SENDER_NAME=Служба доставки
